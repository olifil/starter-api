# =============================================================================
# Application
# =============================================================================

# Environnement d'exécution : development | production | test
NODE_ENV=development

# Port d'écoute du serveur HTTP
PORT=3000

# Préfixe global des routes API
API_PREFIX=api/v1

# URL publique du frontend (utilisée pour les redirections dans les emails)
FRONTEND_URL=http://localhost:4200

# Chemin frontend ajouté à FRONTEND_URL pour les liens de vérification d'email
EMAIL_VERIFICATION_PATH=/verify-email

# Adresse email de réception des messages du formulaire de contact
CONTACT_EMAIL=contact@starter.local

# =============================================================================
# Base de données (PostgreSQL)
# =============================================================================

# Identifiants de connexion PostgreSQL (utilisés par Docker Compose)
DB_USERNAME=starter
DB_PASSWORD=starter123
DB_NAME=starter_db
DB_PORT=5432

# URL de connexion complète utilisée par Prisma (doit correspondre aux valeurs ci-dessus)
DATABASE_URL="postgresql://starter:starter123@localhost:5432/starter_db?schema=public"

# =============================================================================
# JWT (JSON Web Tokens)
# =============================================================================

# Secret de l'access token (minimum 32 caractères — générer avec : make secrets-generate)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Durée de vie de l'access token (ex: 15m, 1h)
JWT_EXPIRATION=15m

# Secret du refresh token (doit être différent de JWT_SECRET)
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters-long

# Durée de vie du refresh token
JWT_REFRESH_EXPIRATION=7d

# Secret du token de réinitialisation de mot de passe
JWT_RESET_SECRET=your-reset-secret-minimum-32-characters-long

# Durée de vie du token de réinitialisation
JWT_RESET_EXPIRATION=15m

# Secret du token de vérification d'adresse email
JWT_VERIFICATION_SECRET=your-verification-secret-minimum-32-characters-long

# Durée de vie du token de vérification
JWT_VERIFICATION_EXPIRATION=7d

# =============================================================================
# CORS
# =============================================================================

# Activer le middleware CORS
ENABLE_CORS=true

# Origines autorisées, séparées par des virgules
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# Rate Limiting (@nestjs/throttler)
# =============================================================================

# Throttler général — appliqué à toutes les routes
THROTTLE_DEFAULT_TTL=60
THROTTLE_DEFAULT_LIMIT=30

# Throttler strict — appliqué aux routes sensibles (login, register, forgot-password)
THROTTLE_STRICT_TTL=60
THROTTLE_STRICT_LIMIT=5

# =============================================================================
# Redis (BullMQ — file de traitement des notifications)
# =============================================================================

# Hôte Redis
REDIS_HOST=localhost

# Port Redis
REDIS_PORT=6379

# Mot de passe Redis (laisser vide si non sécurisé en développement)
REDIS_PASSWORD=

# =============================================================================
# Email SMTP (optionnel — canal désactivé si SMTP_HOST est absent)
# En développement : Mailhog écoute sur localhost:1025
# En production : utiliser un service SMTP réel (ex: port 587 avec STARTTLS)
# =============================================================================

# Hôte du serveur SMTP
SMTP_HOST=localhost

# Port SMTP (1025 = Mailhog / 587 = STARTTLS prod / 465 = SSL prod)
SMTP_PORT=1025

# Activer TLS (true pour le port 465, false pour 587/1025)
SMTP_SECURE=false

# Identifiant SMTP (laisser vide pour Mailhog)
SMTP_USER=

# Mot de passe SMTP (laisser vide pour Mailhog)
SMTP_PASSWORD=

# Adresse expéditeur des emails
SMTP_FROM=noreply@starter.local

# =============================================================================
# SMS (optionnel — interface abstraite, aucune implémentation fournie)
# Implémenter src/modules/notification/infrastructure/channels/sms/
# =============================================================================

# Fournisseur SMS (ex: twilio, ovh, vonage)
SMS_PROVIDER=

# Clé API du fournisseur SMS
SMS_API_KEY=

# Numéro ou nom d'expéditeur SMS
SMS_FROM=

# =============================================================================
# Push mobile (optionnel — interface abstraite, aucune implémentation fournie)
# Implémenter src/modules/notification/infrastructure/channels/push/
# =============================================================================

# ID du projet Firebase Cloud Messaging
FCM_PROJECT_ID=

# Clé privée du compte de service Firebase (format JSON sur une ligne)
FCM_PRIVATE_KEY=

# Email du compte de service Firebase
FCM_CLIENT_EMAIL=

# =============================================================================
# Web Push (optionnel — canal désactivé si VAPID_PUBLIC_KEY est absent)
# Générer les clés VAPID : npx web-push generate-vapid-keys
# =============================================================================

# Clé publique VAPID (transmise au navigateur pour s'abonner)
VAPID_PUBLIC_KEY=

# Clé privée VAPID (gardée côté serveur)
VAPID_PRIVATE_KEY=

# Contact VAPID requis par la spécification Web Push (mailto: ou URL)
VAPID_SUBJECT=mailto:admin@starter.local

# =============================================================================
# WebSocket
# =============================================================================

# Activer le canal de notifications en temps réel via WebSocket
WS_ENABLED=true

# =============================================================================
# Health monitoring (surveillance automatique toutes les 5 minutes)
# =============================================================================

# Activer les notifications SUPER_ADMIN lors d'une dégradation ou d'un rétablissement
# Mettre à "false" pour désactiver les alertes (les checks continuent de tourner en arrière-plan)
HEALTH_MONITOR_NOTIFICATIONS_ENABLED=true

# =============================================================================
# Internationalisation (i18n)
# =============================================================================

# Langue par défaut des notifications (doit correspondre à un dossier dans resources/i18n/)
DEFAULT_LANGUAGE=fr

# Langue de secours si une clé de traduction est absente dans DEFAULT_LANGUAGE
FALLBACK_LANGUAGE=en

# =============================================================================
# Matomo Analytics (optionnel)
# =============================================================================

# URL de l'instance Matomo
MATOMO_URL=http://localhost:8080

# Port Matomo (utilisé par Docker Compose)
MATOMO_PORT=8080

# ID du site dans Matomo (visible dans Administration > Sites)
MATOMO_SITE_ID=1

# Token API Matomo (Administration > API > Authentification utilisateur)
MATOMO_TOKEN=

# =============================================================================
# Storage S3 (non implémenté — réservé pour une future extension)
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-3
# AWS_S3_BUCKET=my-uploads
